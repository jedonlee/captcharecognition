# Environment Configuration Example
# Copy this file to .env and fill in your values

# Device Configuration
CUDA_VISIBLE_DEVICES=0
DEVICE=auto

# Model Configuration
NUM_CLASSES=62
MAX_LENGTH=6

# Data Paths
DATA_ROOT=data
CHECKPOINT_DIR=checkpoints
LOG_DIR=logs
RESULTS_DIR=results

# Training Configuration
NUM_WORKERS=4
PIN_MEMORY=true
PREFETCH_FACTOR=2

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# API (if needed)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
